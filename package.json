{
  "name": "youtube-auto-hd",
  "description": "Automatically set the video quality on YouTube according to its FPS!",
  "private": true,
  "version": "1.16.1",
  "type": "module",
  "license": "GPL-3.0-or-later",
  "repository": "https://github.com/avi12/youtube-auto-hd",
  "homepage": "https://github.com/avi12/youtube-auto-hd",
  "author": "Avi <avi6106@gmail.com>",
  "scripts": {
    "dev": "wxt",
    "dev:with-profile": "bunx cross-env CHROME_PROFILE=Default CHROME_INSTANCE=1 wxt",
    "dev:rtl": "bunx cross-env VITE_LANG=he wxt",
    "dev:edge": "bun dev -b edge",
    "dev:opera": "bun dev -b opera",
    "dev:firefox": "wxt -b firefox --mv3",
    "dev:firefox:with-profile": "bunx cross-env FIREFOX_PROFILE=1 wxt -b firefox --mv3",
    "dev:screenshot": "bunx cross-env BLANK=1 LANG=szl bun dev",
    "dev:screenshot:opera": "bun dev:screenshot -b opera",
    "dev:screenshot:edge": "bun dev:screenshot -b edge",
    "build": "wxt build",
    "build:edge": "bun run build -b edge",
    "build:opera": "bun run build -b opera",
    "build:firefox": "bun run build -b firefox --mv3",
    "package": "wxt zip",
    "package:edge": "bun run package -b edge",
    "package:opera": "bun run package -b opera",
    "package:firefox": "bun run package -b firefox --mv3",
    "build:package": "bun run build && bun run package",
    "build:package:edge": "bun build:edge && bun package:edge",
    "build:package:opera": "bun build:opera && bun package:opera",
    "build:package:firefox": "bun build:firefox && bun package:firefox",
    "build:package:all": "bunx concurrently \"bun build:package\" \"bun build:package:edge\" \"bun build:package:opera\" \"bun build:package:firefox\" --names Chrome,Edge,Opera,Firefox",
    "svelte:check": "bunx svelte-check",
    "lint:fix": "eslint --fix",
    "lint:css": "stylelint . --fix",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "@webext-core/messaging": "^2.3.0",
    "ccc-components": "^0.18.0",
    "nouislider": "^15.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/chrome": "^0.1.39",
    "@types/node": "^25.5.2",
    "@wxt-dev/module-svelte": "^2.0.5",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.2.0",
    "eslint-config-avi12": "github:avi12/eslint-config-avi12",
    "eslint-plugin-import-newlines": "^2.0.0",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.6.0",
    "stylelint-config-ccb": "^3.31.1",
    "svelte": "^5.55.1",
    "svelte-eslint-parser": "^1.6.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "webext-store-incompat-fixer": "^0.25.0",
    "wxt": "^0.20.20"
  }
}
